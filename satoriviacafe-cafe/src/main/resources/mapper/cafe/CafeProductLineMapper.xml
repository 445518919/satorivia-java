<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.satoriviacafe.cafe.mapper.CafeProductLineMapper">
    <resultMap type="CafeProductLine" id="CafeProductLineResult">
        <result property="lineId" column="line_id"/>
        <result property="lineCode" column="line_code"/>
        <result property="seriesCode" column="series_code"/>
        <result property="lineName" column="line_name"/>
        <result property="lineSubTitle" column="line_sub_title"/>
        <result property="lineDescription" column="line_description"/>
        <result property="coverImage" column="cover_image"/>
        <result property="mobileCoverImage" column="mobile_cover_image"/>
        <result property="seoTitle" column="seo_title"/>
        <result property="seoDescription" column="seo_description"/>
        <result property="lineSort" column="line_sort"/>
        <result property="lineStatus" column="line_status"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <result property="deleteAt" column="delete_at"/>
    </resultMap>

    <sql id="selectCafeProductLineVo">
        select line_id,
               line_code,
               series_code,
               line_name,
               line_sub_title,
               line_description,
               cover_image,
               mobile_cover_image,
               seo_title,
               seo_description,
               line_sort,
               line_status,
               create_by,
               create_time,
               update_by,
               update_time,
               delete_at
        from cafe_product_line
    </sql>

    <select id="selectCafeProductLineList" parameterType="CafeProductLine" resultMap="CafeProductLineResult">
        <include refid="selectCafeProductLineVo"/>
        <where>
            <if test="lineCode != null  and lineCode != ''">
                and line_code = #{lineCode}
            </if>
            <if test="seriesCode != null  and seriesCode != ''">
                and series_code = #{seriesCode}
            </if>
            <if test="lineName != null  and lineName != ''">
                and line_name like concat('%', #{lineName}, '%')
            </if>
            <if test="lineSubTitle != null  and lineSubTitle != ''">
                and line_sub_title = #{lineSubTitle}
            </if>
            <if test="lineDescription != null  and lineDescription != ''">
                and line_description = #{lineDescription}
            </if>
            <if test="coverImage != null  and coverImage != ''">
                and cover_image = #{coverImage}
            </if>
            <if test="mobileCoverImage != null  and mobileCoverImage != ''">
                and mobile_cover_image = #{mobileCoverImage}
            </if>
            <if test="seoTitle != null  and seoTitle != ''">
                and seo_title = #{seoTitle}
            </if>
            <if test="seoDescription != null  and seoDescription != ''">
                and seo_description = #{seoDescription}
            </if>
            <if test="lineSort != null">
                and line_sort = #{lineSort}
            </if>
            <if test="lineStatus != null  and lineStatus != ''">
                and line_status = #{lineStatus}
            </if>
            and delete_at IS NULL
        </where>
    </select>

    <select id="selectCafeProductLineByLineId" parameterType="Long" resultMap="CafeProductLineResult">
        <include refid="selectCafeProductLineVo"/>
        where line_id = #{lineId}
        and delete_at IS NULL
    </select>

    <insert id="insertCafeProductLine" parameterType="CafeProductLine" useGeneratedKeys="true" keyProperty="lineId">
        insert into cafe_product_line
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="lineCode != null and lineCode != ''">
                line_code,
            </if>
            <if test="seriesCode != null and seriesCode != ''">
                series_code,
            </if>
            <if test="lineName != null and lineName != ''">
                line_name,
            </if>
            <if test="lineSubTitle != null">
                line_sub_title,
            </if>
            <if test="lineDescription != null">
                line_description,
            </if>
            <if test="coverImage != null and coverImage != ''">
                cover_image,
            </if>
            <if test="mobileCoverImage != null">
                mobile_cover_image,
            </if>
            <if test="seoTitle != null">
                seo_title,
            </if>
            <if test="seoDescription != null">
                seo_description,
            </if>
            <if test="lineSort != null">
                line_sort,
            </if>
            <if test="lineStatus != null">
                line_status,
            </if>
            <if test="createBy != null">
                create_by,
            </if>
            <if test="createTime != null">
                create_time,
            </if>
            <if test="updateBy != null">
                update_by,
            </if>
            <if test="updateTime != null">
                update_time,
            </if>
            <if test="deleteAt != null">
                delete_at,
            </if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="lineCode != null and lineCode != ''">
                #{lineCode},
            </if>
            <if test="seriesCode != null and seriesCode != ''">
                #{seriesCode},
            </if>
            <if test="lineName != null and lineName != ''">
                #{lineName},
            </if>
            <if test="lineSubTitle != null">
                #{lineSubTitle},
            </if>
            <if test="lineDescription != null">
                #{lineDescription},
            </if>
            <if test="coverImage != null and coverImage != ''">
                #{coverImage},
            </if>
            <if test="mobileCoverImage != null">
                #{mobileCoverImage},
            </if>
            <if test="seoTitle != null">
                #{seoTitle},
            </if>
            <if test="seoDescription != null">
                #{seoDescription},
            </if>
            <if test="lineSort != null">
                #{lineSort},
            </if>
            <if test="lineStatus != null">
                #{lineStatus},
            </if>
            <if test="createBy != null">
