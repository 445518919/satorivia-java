    <update id="deleteCafeProductLineByLineId" parameterType="Long">
        update cafe_product_line
        set delete_at = now()
        where line_id = #{lineId}
        and delete_at IS NULL
    </update>

    <update id="deleteCafeProductLineByLineIds" parameterType="String">
        update cafe_product_line
        set delete_at = now()
        where line_id in
        <foreach item="lineId" collection="array" open="(" separator="," close=")">
            #{lineId}
        </foreach>
        and delete_at IS NULL
    </update>
