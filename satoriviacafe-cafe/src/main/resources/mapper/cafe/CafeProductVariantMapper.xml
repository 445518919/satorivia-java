                </if>
                <if test="item.variantName != null and item.variantName != ''">
                    variant_name = #{item.variantName},
                </if>
                <if test="item.skuCode != null">
                    sku_code = #{item.skuCode},
                </if>
                <if test="item.netContent != null">
                    net_content = #{item.netContent},
                </if>
                <if test="item.salePrice != null">
                    sale_price = #{item.salePrice},
                </if>
