    <update id="updateCafeProductVariant" parameterType="CafeProductVariant">
        update cafe_product_variant
        <trim prefix="SET" suffixOverrides=",">
            <if test="productId != null">
                product_id = #{productId},
            </if>
            <if test="variantName != null and variantName != ''">
                variant_name = #{variantName},
            </if>
            <if test="skuCode != null">
                sku_code = #{skuCode},
            </if>
            <if test="netContent != null">
                net_content = #{netContent},
            </if>
            <if test="salePrice != null">
                sale_price = #{salePrice},
            </if>
            <if test="marketPrice != null">
                market_price = #{marketPrice},
            </if>
            <if test="stockStatus != null">
                stock_status = #{stockStatus},
            </if>
            <if test="purchaseUrl != null">
                purchase_url = #{purchaseUrl},
            </if>
            <if test="variantSort != null">
                variant_sort = #{variantSort},
            </if>
            <if test="variantStatus != null">
                variant_status = #{variantStatus},
            </if>
            <if test="createBy != null">
                create_by = #{createBy},
            </if>
            <if test="createTime != null">
                create_time = #{createTime},
            </if>
            <if test="updateBy != null">
                update_by = #{updateBy},
            </if>
            <if test="updateTime != null">
                update_time = #{updateTime},
            </if>
            <if test="deleteAt != null">
                delete_at = #{deleteAt},
            </if>
        </trim>
        where variant_id = #{variantId}
        and delete_at IS NULL
    </update>

