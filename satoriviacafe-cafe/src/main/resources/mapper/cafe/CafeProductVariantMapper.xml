    <update id="deleteCafeProductVariantByVariantId" parameterType="Long">
        update cafe_product_variant
        set delete_at = now()
        where variant_id = #{variantId}
        and delete_at IS NULL
    </update>

    <update id="deleteCafeProductVariantByVariantIds" parameterType="String">
        update cafe_product_variant
        set delete_at = now()
        where variant_id in
        <foreach item="variantId" collection="array" open="(" separator="," close=")">
            #{variantId}
        </foreach>
        and delete_at IS NULL
    </update>
</mapper>
