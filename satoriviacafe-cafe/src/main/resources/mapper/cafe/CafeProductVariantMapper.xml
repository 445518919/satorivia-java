                #{item.deleteAt},
            </trim>
            )
        </foreach>
    </insert>

    <insert id="insertBatchIgnoreCafeProductVariant" useGeneratedKeys="true" keyProperty="variantId">
        insert ignore into cafe_product_variant
        <trim prefix="(" suffix=")" suffixOverrides=",">
