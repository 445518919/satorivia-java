<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.satoriviacafe.cafe.mapper.CafeProductNfcMapper">
    <resultMap type="CafeProductNfc" id="CafeProductNfcResult">
        <result property="nfcId"    column="nfc_id"/>
        <result property="nfcCode"    column="nfc_code"/>
        <result property="skuCode"    column="sku_code"/>
        <result property="productName"    column="product_name"/>
        <result property="batchName"    column="batch_name"/>
        <result property="createBy"    column="create_by"/>
        <result property="createTime"    column="create_time"/>
        <result property="updateBy"    column="update_by"/>
        <result property="updateTime"    column="update_time"/>
        <result property="deleteAt"    column="delete_at"/>
        <result property="nfcHash"    column="nfc_hash"/>
        <result property="nfcUrl"    column="nfc_url"/>
    </resultMap>

    <sql id="selectCafeProductNfcVo">
        select nfc_id, nfc_code, sku_code, product_name, batch_name, create_by, create_time, update_by, update_time, delete_at, nfc_hash, nfc_url from cafe_product_nfc
    </sql>

    <select id="selectCafeProductNfcList" parameterType="CafeProductNfc" resultMap="CafeProductNfcResult">
        <include refid="selectCafeProductNfcVo"/>
        <where>
            <if test="nfcCode != null  and nfcCode != ''"> and nfc_code = #{nfcCode}</if>
            <if test="skuCode != null "> and sku_code = #{skuCode}</if>
            <if test="productName != null  and productName != ''"> and product_name like concat('%', #{productName}, '%')</if>
            <if test="batchName != null  and batchName != ''"> and batch_name like concat('%', #{batchName}, '%')</if>
            <if test="nfcHash != null  and nfcHash != ''"> and nfc_hash = #{nfcHash}</if>
            <if test="nfcUrl != null  and nfcUrl != ''"> and nfc_url = #{nfcUrl}</if>
        and delete_at IS NULL
</where>
        </select>

<select id="selectCafeProductNfcByNfcId" parameterType="Long" resultMap="CafeProductNfcResult">
    <include refid="selectCafeProductNfcVo"/>
    where nfc_id = #{nfcId}
    and delete_at IS NULL
</select>

<insert id="insertCafeProductNfc" parameterType="CafeProductNfc" useGeneratedKeys="true" keyProperty="nfcId">
insert into cafe_product_nfc
<trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="nfcCode != null and nfcCode != ''">nfc_code,</if>
            <if test="skuCode != null">sku_code,</if>
            <if test="productName != null and productName != ''">product_name,</if>
            <if test="batchName != null and batchName != ''">batch_name,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="deleteAt != null">delete_at,</if>
            <if test="nfcHash != null">nfc_hash,</if>
            <if test="nfcUrl != null">nfc_url,</if>
</trim>
<trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="nfcCode != null and nfcCode != ''">#{nfcCode},</if>
            <if test="skuCode != null">#{skuCode},</if>
