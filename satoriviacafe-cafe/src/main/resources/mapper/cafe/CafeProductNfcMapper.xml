<update id="deleteCafeProductNfcByNfcId" parameterType="Long">
update cafe_product_nfc
set delete_at = now()
where nfc_id = #{nfcId}
and delete_at IS NULL
</update>

<update id="deleteCafeProductNfcByNfcIds" parameterType="String">
