     * @return 结果
     */
    #if($table.sub)
    @Transactional
    #end
    @Override
    public int updateBatch${ClassName}(List<${ClassName}> ${className}s) {
        #foreach ($column in $columns)
        #if($column.javaField == 'updateTime')
            for (${ClassName} ${className} : ${className}s) {
                ${className}.setUpdateTime(DateUtils.getNowDate());
            }
        #end
        #end
        #if($table.sub)
            for (${ClassName} parent : ${className}s){
                ${className}Mapper.delete${subClassName}By${subTableFkClassName}(parent.get${pkColumn.capJavaField}());
                insert${subClassName}(parent); // 使用辅助方法为当前父实体插入子实体
            }
        }
        #end
        return ${className}Mapper.updateBatch${ClassName}(${className}s);
    }

