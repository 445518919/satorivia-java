     */
    #if($table.sub)
    @Transactional
    #end
    @Override
    public int insertBatch${ClassName}(List<${ClassName}> ${className}s, boolean ignorePk) {
#foreach ($column in $columns)
    #if($column.javaField == 'createTime')
        for (${ClassName} ${className} : ${className}s) {
            ${className}.setCreateTime(DateUtils.getNowDate());
        }
    #end
#end
#if($table.sub)
        int rows = ${className}Mapper.insertBatch${ClassName}(${className}s);
        for (${ClassName} parent : ${className}s) {
            insert${subClassName}(parent);
        }
        return rows;
#else
        if(ignorePk) {
            return  ${className}Mapper.insertBatchIgnore${ClassName}(${className}s);
        }
        return ${className}Mapper.insertBatch${ClassName}(${className}s);
#end
    }

